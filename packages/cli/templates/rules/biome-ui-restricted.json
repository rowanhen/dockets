{
	"$schema": "https://biomejs.dev/schemas/2.0.0/schema.json",
	"linter": {
		"rules": {
			"style": {
				"noRestrictedImports": {
					"level": "error",
					"options": {
						"patterns": [
							{
								"group": ["@/components/ui/*"],
								"message": "Do not import directly from 'components/ui/'. Import from 'components/ui-opinionated/' instead. Only ui-opinionated wrappers should reference ui/ primitives."
							}
						]
					}
				}
			}
		}
	},
	"overrides": [
		{
			"includes": ["src/components/ui-opinionated/**"],
			"linter": {
				"rules": {
					"style": {
						"noRestrictedImports": "off"
					}
				}
			}
		}
	]
}
